<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local2="using:Kyotanabe.Templates"
    xmlns:local="using:Kyotanabe">

    <Style TargetType="local2:ValidationTextBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local2:ValidationTextBox">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <StackPanel>
                            <TextBox Name="TextBox" Text="{TemplateBinding Text}" Header="{TemplateBinding Header}" PlaceholderText="{TemplateBinding PlaceholderText}"/>
                            <TextBlock Name="Message" Text="{TemplateBinding Message}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local2:ValidationNumberBox" xmlns:component="using:System.ComponentModel.DataAnnotations">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local2:ValidationNumberBox">
                    <StackPanel Orientation="Vertical">
                        <NumberBox
                            Name="Value"
                            Value="{TemplateBinding Value}"
                            Header="{TemplateBinding Header}"/>
                        <TextBlock Name="Message" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
