<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local2="using:Kyotanabe.Templates"
    xmlns:local="using:Kyotanabe">

    <Style TargetType="local2:ValidationTextBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local2:ValidationTextBox">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <StackPanel>
                            <TextBox Name="TextBox" Text="{TemplateBinding Text}" Header="{TemplateBinding Header}" PlaceholderText="{TemplateBinding PlaceholderText}"/>
                            <TextBlock Name="Message" Text="{TemplateBinding Message}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local2:ValidationNumberBox" xmlns:component="using:System.ComponentModel.DataAnnotations">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local2:ValidationNumberBox">
                    <StackPanel Orientation="Vertical">
                        <NumberBox
                            Name="Value"
                            Value="{TemplateBinding Value}"
                            Header="{TemplateBinding Header}"/>
                        <TextBlock Name="Message" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local2:EditControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local2:EditControl">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="EditIntro"/>
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                Grid.Row="1"/>
                            <CommandBar
                                DefaultLabelPosition="Right"
                                Grid.Row="3">
                                <AppBarButton
                                    x:Uid="/FieldResources/SaveBtn"
                                    Icon="Save"
                                    Command="{TemplateBinding SaveCommand}"/>
                                <AppBarButton
                                    x:Uid="/FieldResources/RemoveBtn"
                                    Icon="Delete">
                                    <AppBarButton.Flyout>
                                        <Flyout>
                                            <StackPanel>
                                                <TextBlock x:Uid="RemoveMessage" Style="{StaticResource BaseTextBlockStyle}"/>
                                                <Button
                                                    x:Uid="/FieldResources/DeleteConfirmBtn"
                                                    Command="{TemplateBinding RemoveCommand}"/>
                                            </StackPanel>
                                        </Flyout>
                                    </AppBarButton.Flyout>
                                </AppBarButton>
                            </CommandBar>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local2:ViewBaseControl" xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors" xmlns:interactivity="using:Microsoft.Xaml.Interactivity">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local2:ViewBaseControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListView
                            Name="PART_ListView"
                            ItemsSource="{TemplateBinding ItemsSource}"
                            ItemTemplate="{TemplateBinding TableRowTemplate}"
                            SelectedItem="{TemplateBinding RemoveCommandParameter}">
                            <ListView.Header>
                                <Border Padding="12,0,0,0">
                                    <interactivity:Interaction.Behaviors>
                                        <behaviors:StickyHeaderBehavior/>
                                    </interactivity:Interaction.Behaviors>
                                    <ContentPresenter Content="{TemplateBinding TableHeader}"/>
                                </Border>
                            </ListView.Header>
                            <ListView.ItemContainerStyle>
                                <Style
                                    TargetType="ListViewItem"
                                    BasedOn="{StaticResource DefaultListViewItemStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                        <ContentPresenter
                            Grid.Row="1"
                            Content="{TemplateBinding AdditionalContent}"/>
                        <CommandBar
                            Grid.Row="2"
                            DefaultLabelPosition="Right">
                            <AppBarButton
                                x:Uid="/FieldResources/AddBtn"
                                Command="{TemplateBinding AddCommand}"
                                Icon="Add"/>
                            <AppBarButton
                                x:Uid="/FieldResources/RemoveBtn"
                                Icon="Delete">
                                <AppBarButton.Flyout>
                                    <Flyout>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BaseTextBlockStyle}" x:Uid="/FieldResources/RemoveMessage"/>
                                            <Button
                                                x:Uid="/FieldResources/RemoveConfirmBtn"
                                                Command="{TemplateBinding RemoveCommand}"
                                                CommandParameter="{TemplateBinding RemoveCommandParameter}"/>
                                        </StackPanel>
                                    </Flyout>
                                </AppBarButton.Flyout>
                            </AppBarButton>
                            <AppBarButton
                                x:Uid="/FieldResources/LoadBtn"
                                Icon="Download"
                                Command="{TemplateBinding LoadCommand}"/>
                        </CommandBar>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
