<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Kyotanabe.CategoriesViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kyotanabe"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:models="using:Kizu.Models"
    xmlns:controls2="using:Kyotanabe.Templates"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock
            x:Uid="CategoriesIntro"
            Style="{StaticResource BodyTextBlockStyle}"/>

        <controls2:ViewBaseControl
            Grid.Row="1"
            ItemsSource="{x:Bind viewModel.Categories}"
            AddCommand="{x:Bind viewModel.AddCommand}"
            RemoveCommand="{x:Bind viewModel.RemoveCommand}"
            LoadCommand="{x:Bind viewModel.LoadCommand}">
            <controls2:ViewBaseControl.TableHeader>
                <controls:DataTable>
                    <controls:DataColumn
                        x:Uid="/ColumnResources/Identifier"
                        DesiredWidth="80"/>
                    <controls:DataColumn
                        x:Uid="/ColumnResources/Name"
                        DesiredWidth="*"/>
                    <controls:DataColumn
                        x:Uid="/ColumnResources/Budget"
                        DesiredWidth="100"/>
                </controls:DataTable>
            </controls2:ViewBaseControl.TableHeader>
            <controls2:ViewBaseControl.TableRowTemplate>
                <DataTemplate x:DataType="models:Category">
                    <controls:DataRow>
                        <TextBlock Text="{x:Bind Id}"/>
                        <TextBlock Text="{x:Bind Name}"/>
                        <TextBlock Text="{x:Bind Budget}"/>
                    </controls:DataRow>
                </DataTemplate>
            </controls2:ViewBaseControl.TableRowTemplate>
        </controls2:ViewBaseControl>
    </Grid>
</Page>
