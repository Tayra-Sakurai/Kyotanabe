<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    x:Class="Kyotanabe.ComboBoxTemplateDictionary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Kizu.Models"
    xmlns:local="using:Kyotanabe">
    <DataTemplate
        x:Key="CategoryComboBoxItemTemplate"
        x:DataType="models:Category">
        <TextBlock Text="{x:Bind Name}"/>
    </DataTemplate>
    <DataTemplate
        x:Key="PaymentMethodComboBoxTemplate"
        x:DataType="models:PaymentMethod">
        <TextBlock Text="{x:Bind Name}"/>
    </DataTemplate>
</ResourceDictionary>
