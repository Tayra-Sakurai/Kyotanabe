<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Kyotanabe.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Kizu.Models"
    xmlns:local="using:Kyotanabe">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
            <Style
                TargetType="ComboBox"
                x:Key="CategorySelectComboBoxStyle"
                BasedOn="{StaticResource DefaultComboBoxStyle}">
                <Setter Property="ItemTemplate">
                    <Setter.Value>
                        <DataTemplate x:DataType="models:Category">
                            <TextBlock Text="{x:Bind Name}"/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style
                            TargetType="ComboBoxItem"
                            BasedOn="{StaticResource DefaultComboBoxItemStyle}"/>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style
                TargetType="ComboBox"
                x:Key="PaymentMethodSelectComboBoxStyle"
                BasedOn="{StaticResource DefaultComboBoxStyle}">
                <Setter Property="ItemTemplate">
                    <Setter.Value>
                        <DataTemplate x:DataType="models:PaymentMethod">
                            <TextBlock Text="{x:Bind Name}"/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
