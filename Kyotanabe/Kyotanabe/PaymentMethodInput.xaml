<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Kyotanabe.PaymentMethodInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kyotanabe"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Kyotanabe.Templates"
    xmlns:models="using:Kizu.Models"
    xmlns:viewmodels="using:Kizu.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:PaymentMethodViewModel}"
    mc:Ignorable="d">

    <StackPanel
        Orientation="Vertical"
        Spacing="8">
        <controls:ValidationTextBox
            x:Uid="/FieldResources/Name"
            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Property="Name"/>
        <ComboBox
            x:Uid="/FieldResources/Account"
            ItemsSource="{Binding Accounts}"
            SelectedItem="{Binding Account, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:Account">
                    <TextBlock Text="{x:Bind Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <NumberBox
            x:Uid="/FieldResources/Balance"
            Value="{Binding Balance, Mode=OneWay}"/>
    </StackPanel>
</UserControl>
