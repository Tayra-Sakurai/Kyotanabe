<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Kyotanabe.CategoryInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kyotanabe"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Kizu.ViewModels"
    xmlns:controls="using:Kyotanabe.Templates"
    d:DataContext="{d:DesignInstance Type=viewmodels:CategoryViewModel}"
    mc:Ignorable="d">

    <StackPanel
        Spacing="8"
        Orientation="Vertical">
        <controls:ValidationTextBox
            x:Uid="/FieldResources/Name"
            Text="{Binding CategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Property="CategoryName"/>
        <controls:ValidationNumberBox
            x:Uid="/FieldResources/Budget"
            Value="{Binding Budget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            PropertyName="Budget"/>
    </StackPanel>
</UserControl>
