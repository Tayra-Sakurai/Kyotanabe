<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Kyotanabe.ItemsViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kyotanabe"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:models="using:Kizu.Models"
    mc:Ignorable="d">

    <Grid
        RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="ItemsIntro"
            Style="{StaticResource BodyTextBlockStyle}"
            TextWrapping="WrapWholeWords"/>

        <ListView
            ItemsSource="{x:Bind viewModel.Items}"
            x:Name="TheTable"
            Grid.Row="1">
            <ListView.Header>
                <Border Padding="12 0 0 0">
                    <interactivity:Interaction.Behaviors>
                        <behaviors:StickyHeaderBehavior/>
                    </interactivity:Interaction.Behaviors>
                    <controls:DataTable>
                        <controls:DataColumn
                            x:Uid="/ColumnResources/Identifier"
                            DesiredWidth="80"/>
                        <controls:DataColumn
                            x:Uid="/ColumnResouces/Category"
                            DesiredWidth="*"/>
                        <controls:DataColumn
                            x:Uid="/ColumnResources/Name"
                            DesiredWidth="3*"/>
                        <controls:DataColumn
                            x:Uid="/ColumnResources/DateTime"
                            DesiredWidth="100"/>
                        <controls:DataColumn
                            x:Uid="/ColumnResources/Method"/>
                        <controls:DataColumn
                            x:Uid="/ColumnResources/Income"/>
                        <controls:DataColumn
                            x:Uid="/ColumnResources/Expense"/>
                    </controls:DataTable>
                </Border>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <controls:DataRow>
                        <TextBlock Text="{x:Bind Id}"/>
                        <TextBlock Text="{x:Bind Category.Name}"/>
                        <TextBlock Text="{x:Bind ItemName}"/>
                        <TextBlock Text="{x:Bind DateTime}"/>
                        <TextBlock Text="{x:Bind PaymentMethod.Name}"/>
                        <TextBlock Text="{x:Bind Income}"/>
                        <TextBlock Text="{x:Bind Expense}"/>
                    </controls:DataRow>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Border Grid.Row="2">
            <Grid
                ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox
                    x:Uid="/FieldResources/Category"
                    ItemsSource="{x:Bind viewModel.Categories}"
                    SelectedItem="{x:Bind viewModel.SelectedCategory}"
                    ItemTemplate="{StaticResource CategoryComboBoxItemTemplate}"/>
                <TextBox
                    Grid.Column="1"
                    x:Uid="/FieldResources/Search"
                    Text="{x:Bind viewModel.Query}"/>
            </Grid>
        </Border>

        <CommandBar
            Grid.Row="3"
            DefaultLabelPosition="Right">
            <AppBarButton
                x:Uid="/FieldResources/AddBtn"
                Icon="Add"
                Command="{x:Bind viewModel.AddCommand}"/>
            <AppBarButton
                x:Uid="/FieldResources/RemoveBtn"
                Icon="Remove"
                Command="{x:Bind viewModel.RemoveCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=TheTable}"/>
            <AppBarButton
                x:Uid="/FieldResources/LoadBtn"
                Icon="Download"
                Command="{x:Bind viewModel.LoadCommand}"/>
            <AppBarButton
                x:Uid="/FieldResources/DetailBtn"
                Icon="More"
                Command="{x:Bind viewModel.EditCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=TheTable}"/>
            <AppBarButton
                x:Uid="/FieldResources/SearchBtn"
                Icon="Zoom"
                Command="{x:Bind viewModel.SearchCommand}"/>
        </CommandBar>
    </Grid>
</Page>
